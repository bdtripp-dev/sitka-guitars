# ============================================================
# 1. Environment Variables (critical)
# ============================================================
.env
.env.*

# ============================================================
# 2. WordPress Core (provided by Docker image)
# ============================================================
wp/wp-admin/
wp/wp-includes/
wp/wp-*.php
wp/index.php
wp/xmlrpc.php
wp/license.txt
wp/readme.html
wp/.htaccess

# Environment-specific config (never tracked)
wp/wp-config.php

# ============================================================
# 3. wp-content (track themes/plugins, ignore runtime folders)
# ============================================================
wp/wp-content/uploads/
wp/wp-content/cache/
wp/wp-content/upgrade/
wp/wp-content/upgrade-temp-backup/
wp/wp-content/gallery/
wp/wp-content/ngg/
wp/wp-content/debug.log
wp/wp-content/languages/
wp/wp-content/ai1wm-backups/

# ============================================================
# 4. Explicitly keep themes and plugins (your actual code)
# ============================================================
!wp/wp-content/themes/**
!wp/wp-content/plugins/**

# ============================================================
# 5. Build artifacts inside custom themes/plugins only
# ============================================================
wp/wp-content/themes/*/node_modules/
wp/wp-content/plugins/*/node_modules/
wp/wp-content/themes/*/composer.lock
wp/wp-content/plugins/*/composer.lock

# ============================================================
# 6. Logs, OS junk, editor files
# ============================================================
*.log
error_log
*~
**/.DS_Store
Thumbs.db
.vscode/
.idea/

*:Zone.Identifier
secrets/
local.sql
docker-compose.override.yaml